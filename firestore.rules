rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // JSA Work Method/root: projects, wms_documents, jsa_documents, users, appMeta, activityLogs
    match /"JSA Work Method"/root/{subcollection}/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /"JSA Work Method"/_meta {
      allow read, write: if request.auth != null;
    }
  }
}
